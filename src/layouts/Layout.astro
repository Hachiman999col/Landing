---
import '@fontsource/jetbrains-mono';

import "../styles/global.css";

import LanguageToggle from '../components/LanguageToggle.astro';
import Sidebar from '../components/Sidebar.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Diego | Software Engineer</title>
		<meta name="description" content="Diego - Software Engineer specializing in building robust, scalable web and mobile applications with Angular, React, and React Native." />
		<meta property="og:title" content="Diego | Software Engineer" />
		<meta property="og:description" content="Portfolio of Diego - Software Engineer specializing in scalable web and mobile applications." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://Hachiman999col.github.io" />
		<meta property="og:image" content="/og-image.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Diego | Software Engineer" />
		<meta name="twitter:description" content="Portfolio of Diego - Software Engineer specializing in scalable web and mobile applications." />
	</head>
	<body class="bg-grid antialiased">
		<main class="relative p-3 z-0 h-screen flex flex-col overflow-hidden">
			<div class="w-full flex-col flex-1 flex omarchy-window p-1 overflow-hidden">
				
        <header class="border-b border-cyan-400/10 p-2 mb-1">
          <div class="flex justify-between items-center px-2">
            <div class="flex items-center gap-4">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/30"></div>
              </div>
              <span class="text-[10px] text-zinc-500 font-mono tracking-[0.2em] uppercase">HV_v1.1 // {Astro.generator}</span>
            </div>
            <LanguageToggle />
          </div>
        </header>

				<div class="flex flex-1 overflow-hidden">
					<Sidebar />
					<div class="flex-1 overflow-y-auto custom-scrollbar bg-black/10">
						<slot />
					</div>
				</div>
			</div>
		</main>
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

---
import photoMe from "../assets/mel.png";
import { Image } from "astro:assets";
---

<section id="hero" class="flex flex-col md:flex-row items-center justify-between min-h-[80vh] px-8 md:px-16 py-20 gap-16">
  <div class="flex-1 space-y-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 border border-cyan-400/20 bg-cyan-400/5 text-cyan-400 text-[10px] tracking-[0.2em] uppercase">
      <div class="w-1 h-1 bg-cyan-400 rounded-full animate-pulse"></div>
      <span class="lang-en">System Status: Online</span>
      <span class="lang-es">Estado del Sistema: Online</span>
    </div>
    
    <div class="space-y-2">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-white">
        <span class="lang-en opacity-50">INIT:</span>
        <span class="lang-es opacity-50">INIT:</span>
        <span class="text-glow-cyan text-cyan-400">DIEGO</span>
      </h1>
      <div class="h-1 w-20 bg-gradient-to-r from-cyan-400 to-transparent"></div>
    </div>
    
    <div class="text-base md:text-lg text-zinc-400 max-w-xl leading-relaxed font-medium">
      <p class="lang-en">
        Software Engineer specializing in building robust, scalable applications. 
        Focusing on modern web and mobile experiences with high performance and clean architecture.
      </p>
      <p class="lang-es">
        Ingeniero de Software especializado en construir aplicaciones robustas y escalables. 
        Enfocado en experiencias web y móviles modernas con alto rendimiento y arquitectura limpia.
      </p>
    </div>

    <div class="flex flex-wrap gap-4 pt-4">
      <button id="contact-btn" class="h-10 px-8 border border-pink-500/50 bg-pink-500/5 text-pink-500 text-xs font-bold tracking-widest hover:bg-pink-500 hover:text-white transition-all duration-300 rounded-sm">
        <span class="lang-en">CONTACT.SH</span>
        <span class="lang-es">CONTACTO.SH</span>
      </button>
      
      <a 
        href={`${import.meta.env.BASE_URL}cv-eng.pdf`} 
        download
        class="lang-en h-10 px-8 border border-cyan-400/50 bg-cyan-400/5 text-cyan-400 text-xs font-bold tracking-widest hover:bg-cyan-400 hover:text-white transition-all duration-300 rounded-sm no-underline flex items-center"
      >
        RESUME.EXE
      </a>

      <a 
        href={`${import.meta.env.BASE_URL}hv.pdf`}
        download
        class="lang-es h-10 px-8 border border-cyan-400/50 bg-cyan-400/5 text-cyan-400 text-xs font-bold tracking-widest hover:bg-cyan-400 hover:text-white transition-all duration-300 rounded-sm no-underline flex items-center"
      >
        CV.EXE
      </a>
    </div>
  </div>

  <div class="flex-1 flex justify-center items-center">
    <div class="relative w-64 h-64 md:w-80 md:h-80 group">
      <!-- Window Frame (Omarchy Style) -->
      <div class="absolute -inset-4 border border-zinc-800 bg-zinc-900/50 rounded-sm"></div>
      <div class="absolute top-[-16px] left-[-16px] right-[-16px] h-6 border-b border-zinc-800 bg-zinc-800/50 flex items-center px-3 gap-1.5">
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
      </div>
      
      <!-- Screen -->
      <div class="relative w-full h-full overflow-hidden bg-zinc-950 border border-zinc-800 group-hover:border-cyan-400/50 transition-colors duration-500">
        <Image 
          src={photoMe} 
          alt="Diego" 
          class="w-full h-full object-cover object-top grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
        />
        <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-zinc-950 via-transparent to-transparent opacity-50"></div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Modal -->
<div id="contact-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
  <div class="w-full max-w-md bg-zinc-950 border border-zinc-800 shadow-2xl relative animate-in fade-in zoom-in duration-300">
    <!-- Window Header -->
    <div class="flex items-center justify-between px-4 py-2 border-b border-zinc-800 bg-zinc-900/50">
      <div class="flex gap-1.5">
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
        <div class="w-2 h-2 rounded-full bg-zinc-700"></div>
      </div>
      <span class="text-[10px] text-zinc-500 font-mono tracking-widest uppercase">Contact_Info.vcf</span>
      <button id="close-modal" class="text-zinc-500 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    
    <!-- Content -->
    <div class="p-8 space-y-6">
      <div class="space-y-2">
        <label class="text-[10px] text-cyan-400/50 font-bold tracking-[0.2em] uppercase">Email</label>
        <p class="text-white font-mono text-sm break-all select-all cursor-pointer hover:text-cyan-400 transition-colors">bolanosd38@gmail.com</p>
      </div>
      
      <div class="space-y-2">
        <label class="text-[10px] text-pink-500/50 font-bold tracking-[0.2em] uppercase">Phone</label>
        <p class="text-white font-mono text-sm select-all cursor-pointer hover:text-pink-500 transition-colors">+57 316 5310636</p>
      </div>

      <div class="pt-4 flex justify-end">
        <button id="close-modal-btn" class="px-6 py-2 border border-zinc-800 text-zinc-400 text-[10px] font-bold tracking-widest hover:bg-zinc-800 hover:text-white transition-all uppercase">
          <span class="lang-en">Close</span>
          <span class="lang-es">Cerrar</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const contactBtn = document.getElementById('contact-btn');
  const modal = document.getElementById('contact-modal');
  const closeBtns = [document.getElementById('close-modal'), document.getElementById('close-modal-btn')];

  contactBtn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  });

  const closeModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = 'auto';
  };

  closeBtns.forEach(btn => btn?.addEventListener('click', closeModal));

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>

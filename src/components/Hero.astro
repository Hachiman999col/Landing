---
import photoMe from "../assets/mel.png";
import { Image } from "astro:assets";
---

<section class="flex flex-col md:flex-row items-center justify-between min-h-[80vh] px-6 md:px-12 py-20 gap-12">
  <div class="flex-1 space-y-6">
    <div class="inline-block px-3 py-1 border border-cyan-500 text-cyan-400 text-xs tracking-widest uppercase animate-pulse">
      <span class="lang-en">System Status: Online</span>
      <span class="lang-es">Estado del Sistema: Online</span>
    </div>
    
    <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-glow-cyan text-white">
      <span class="lang-en">INITIALIZING:</span>
      <span class="lang-es">INICIALIZANDO:</span>
      <span class="text-cyan-400">DIEGO</span>
    </h1>
    
    <div class="text-lg md:text-xl text-zinc-400 max-w-2xl leading-relaxed">
      <p class="lang-en">
        > A passionate Software Engineer specializing in building robust and scalable applications. 
        Focused on creating modern web and mobile experiences with high performance and elegant design.
      </p>
      <p class="lang-es">
        > Un apasionado Ingeniero de Software especializado en construir aplicaciones robustas y escalables. 
        Enfocado en crear experiencias web y móviles modernas con alto rendimiento y diseño elegante.
      </p>
    </div>

    <div class="flex gap-4 pt-4">
      <div class="h-10 w-40 border-2 border-magenta-500 flex items-center justify-center text-magenta-500 text-sm font-bold cursor-pointer hover:bg-magenta-500 hover:text-white transition-all duration-300 shadow-[0_0_10px_#ff00ff]">
        <span class="lang-en">CONTACT_ME</span>
        <span class="lang-es">CONTACTAME</span>
      </div>
      
      <!-- English Download -->
      <a 
        href="/cv-eng.pdf" 
        download="diegodbpFrontEnd.pdf"
        class="lang-en h-10 w-40 border-2 border-cyan-500 flex items-center justify-center text-cyan-500 text-sm font-bold cursor-pointer hover:bg-cyan-500 hover:text-white transition-all duration-300 shadow-[0_0_10px_#00f3ff] no-underline"
      >
        RESUME.EXE
      </a>

      <!-- Spanish Download -->
      <a 
        href="/hv.pdf" 
        download="diegodbpFrontEnd.pdf"
        class="lang-es h-10 w-40 border-2 border-cyan-500 flex items-center justify-center text-cyan-500 text-sm font-bold cursor-pointer hover:bg-cyan-500 hover:text-white transition-all duration-300 shadow-[0_0_10px_#00f3ff] no-underline"
      >
        CV.EXE
      </a>
    </div>
  </div>

  <div class="flex-1 flex justify-center items-center">
    <div class="relative w-64 h-64 md:w-80 md:h-80 group">
      <!-- Monitor Frame -->
      <div class="absolute -inset-4 border-4 border-zinc-800 rounded-sm bg-zinc-900 shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]"></div>
      <div class="absolute -inset-1 border-2 border-zinc-700"></div>
      
      <!-- Screen -->
      <div class="relative w-full h-full overflow-hidden bg-zinc-800 border-4 border-zinc-900 group-hover:border-cyan-500 transition-colors duration-500">
        <Image 
          src={photoMe} 
          alt="Diego" 
          class="w-full h-full object-cover object-top grayscale contrast-125 brightness-75 group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-700"
        />
        <!-- CRT Screen Overlay -->
        <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle,transparent_50%,rgba(0,0,0,0.4)_100%)]"></div>
        <div class="absolute inset-0 pointer-events-none opacity-20 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%]"></div>
      </div>
      
      <!-- Power LED -->
      <div class="absolute -bottom-2 -right-2 w-3 h-3 bg-green-500 rounded-full shadow-[0_0_8px_#39ff14] animate-pulse"></div>
    </div>
  </div>
</section>

---
interface Project {
  nameEn: string;
  nameEs: string;
  descEn: string;
  descEs: string;
  technologies: string[];
  githubUrl?: string;
}

interface TechDetail {
  id: string;
  name: string;
  internalTools: string[];
  logoUrl: string;
  professionalProjects: Project[];
  personalProjects: Project[];
}

interface Props {
  techDetails: TechDetail[];
}

const { techDetails } = Astro.props;
---

<dialog id="tech-modal" class="bg-transparent backdrop:bg-black/80 backdrop:backdrop-blur-sm w-full h-full border-none outline-none fixed inset-0 z-[100] open:flex items-center justify-center">
  <div class="omarchy-window bg-zinc-950/95 border-cyan-500/30 overflow-hidden flex flex-col w-full max-w-5xl h-[70vh] shadow-2xl shadow-cyan-500/10 relative">
     <!-- Modal Header -->
     <div class="flex justify-between items-center p-4 border-b border-zinc-900 bg-black/40 flex-shrink-0">
        <div class="flex items-center gap-3">
          <div class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></div>
          <h3 class="tm-title text-lg font-bold text-white tracking-[0.2em] uppercase font-mono"></h3>
        </div>
        <button type="button" class="tm-close-btn p-2 text-zinc-500 hover:text-cyan-500 transition-colors hover:bg-cyan-500/5 rounded-sm group/close">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none group-hover/close:rotate-90 transition-transform duration-300"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
     </div>
     
      <!-- Modal Body -->
      <div class="flex-1 overflow-hidden min-h-0">
          <div class="grid grid-cols-1 lg:grid-cols-12 h-full overflow-hidden min-h-0">
            <!-- Left: Info + Logo -->
            <div class="lg:col-span-5 p-8 space-y-10 border-r border-zinc-900/50 overflow-y-auto custom-scrollbar min-h-0">
               <section>
                  <h4 class="text-[10px] text-zinc-500 font-bold tracking-[0.3em] uppercase mb-6 flex items-center gap-3">
                     <span class="w-8 h-[1px] bg-zinc-800"></span>
                     <span class="lang-en">01 // Internal_Tools</span>
                     <span class="lang-es">01 // Herramientas_Internas</span>
                  </h4>
                   <div class="tm-internal-tools flex flex-wrap gap-3"></div>
                </section>
                
                <section>
                   <h4 class="text-[10px] text-zinc-500 font-bold tracking-[0.3em] uppercase mb-6 flex items-center gap-3">
                      <span class="w-8 h-[1px] bg-zinc-800"></span>
                      <span class="lang-en">02 // Core_Architecture</span>
                      <span class="lang-es">02 // Arquitectura_Base</span>
                   </h4>
                   <div class="border border-zinc-900 bg-black/40 rounded-sm p-8 flex flex-col items-center justify-center min-h-[350px] relative overflow-hidden group">
                      <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none bg-grid"></div>
                      
                      <!-- Glitch Logo Container -->
                      <div class="tm-glitch-wrapper relative w-48 h-48 flex items-center justify-center">
                        <!-- Main Logo -->
                        <img class="tm-logo tm-main w-full h-full object-contain relative z-10 filter drop-shadow-[0_0_15px_rgba(6,182,212,0.4)]" src="" alt="Tech Logo" />
                        
                        <!-- Glitch Layers (Placed OVER the main logo) -->
                        <img class="tm-logo tm-glitch tm-glitch-1 absolute top-0 left-0 w-full h-full object-contain z-20 opacity-0 mix-blend-screen pointer-events-none" src="" alt="" />
                        <img class="tm-logo tm-glitch tm-glitch-2 absolute top-0 left-0 w-full h-full object-contain z-20 opacity-0 mix-blend-screen pointer-events-none" src="" alt="" />
                        
                        <!-- Scanline Glitch Overlay -->
                        <div class="tm-scanline absolute inset-0 z-30 opacity-0 pointer-events-none bg-gradient-to-b from-transparent via-cyan-500/10 to-transparent h-4 w-full group-hover:animate-scanline"></div>
                      </div>
                      
                      <div class="absolute bottom-2 right-2 text-right">
                        <div class="text-[7px] text-zinc-800 font-mono">RENDER_MODE: STATIC_ASSET</div>
                        <div class="text-[7px] text-zinc-900 font-mono">GLITCH_ENGINE: v2.0_ENABLED</div>
                      </div>
                   </div>
                </section>
            </div>
            
            <!-- Right: Projects -->
            <div class="lg:col-span-7 p-8 overflow-y-auto custom-scrollbar bg-black/10 min-h-0">
               <div class="space-y-12">
                  <!-- Professional Projects -->
                  <section class="space-y-6">
                     <h4 class="text-[10px] text-zinc-500 font-bold tracking-[0.3em] uppercase flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-zinc-800"></span>
                        <span class="lang-en">03 // Professional_Experience</span>
                        <span class="lang-es">03 // Experiencia_Profesional</span>
                     </h4>
                     <div class="tm-prof-projects-list space-y-4"></div>
                  </section>

                  <!-- Personal Projects -->
                  <section class="space-y-6">
                     <h4 class="text-[10px] text-zinc-500 font-bold tracking-[0.3em] uppercase flex items-center gap-3">
                        <span class="w-8 h-[1px] bg-zinc-800"></span>
                        <span class="lang-en">04 // Personal_Projects</span>
                        <span class="lang-es">04 // Proyectos_Personales</span>
                     </h4>
                     <div class="tm-pers-projects-list space-y-4"></div>
                  </section>
               </div>
            </div>
         </div>
      </div>

      <!-- Footer / Status Bar -->
      <div class="p-2 border-t border-zinc-900 bg-black/20 flex justify-between items-center text-[8px] text-zinc-600 font-mono flex-shrink-0">
        <div>SYS_STATUS: READY</div>
        <div class="flex gap-4">
          <span>MEM_ALLOC: OK</span>
          <span>BUFFER_STREAM: ACTIVE</span>
        </div>
      </div>
  </div>
</dialog>

<script is:inline define:vars={{ techDetails }}>
  function setupTechModal() {
    const modal = document.getElementById('tech-modal');
    const closeBtn = modal?.querySelector('.tm-close-btn');
    const openBtns = document.querySelectorAll('.open-tech-modal-btn');
    
    if (!modal || !closeBtn) return;

    function renderProjectList(projects, isPersonal = false) {
      if (!projects || projects.length === 0) {
        return `
          <div class="text-[10px] text-zinc-600 italic font-mono lang-en">NO_DATA_AVAILABLE</div>
          <div class="text-[10px] text-zinc-600 italic font-mono lang-es">DATOS_NO_DISPONIBLES</div>
        `;
      }

      return projects.map(project => `
        <div class="group/project border border-zinc-900 bg-black/20 p-5 hover:border-cyan-500/30 transition-all duration-300 relative">
          <div class="flex justify-between items-start mb-3">
            <div class="flex-1">
              <h5 class="text-sm font-bold text-white tracking-tight group-hover/project:text-cyan-400 transition-colors lang-en">${project.nameEn}</h5>
              <h5 class="text-sm font-bold text-white tracking-tight group-hover/project:text-cyan-400 transition-colors lang-es">${project.nameEs}</h5>
              <div class="text-[8px] text-zinc-700 font-mono mt-1 lang-en">${isPersonal ? 'PERSONAL_REPO_v1' : 'PROFESSIONAL_EXP_v1'}</div>
              <div class="text-[8px] text-zinc-700 font-mono mt-1 lang-es">${isPersonal ? 'REPO_PERSONAL_v1' : 'EXP_PROFESIONAL_v1'}</div>
            </div>
            ${isPersonal && project.githubUrl ? `
              <a href="${project.githubUrl}" target="_blank" class="ml-4 p-2 border border-zinc-800 hover:border-cyan-500/50 hover:bg-cyan-500/5 text-zinc-500 hover:text-cyan-500 transition-all duration-300 rounded-sm" title="View on GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              </a>
            ` : ''}
          </div>
          <p class="text-[11px] text-zinc-400 leading-relaxed mb-4 font-sans lang-en">
            ${project.descEn}
          </p>
          <p class="text-[11px] text-zinc-400 leading-relaxed mb-4 font-sans lang-es">
            ${project.descEs}
          </p>
          <div class="flex flex-wrap gap-2">
            ${project.technologies.map(t => 
              `<span class="text-[9px] text-zinc-600 font-bold border-l border-zinc-800 pl-2 uppercase">${t}</span>`
            ).join('')}
          </div>
        </div>
      `).join('');
    }

    openBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const techId = btn.getAttribute('data-tech-id');
        const tech = techDetails.find(t => t.id === techId);
        
        if (tech) {
          const titleEl = modal.querySelector('.tm-title');
          const internalEl = modal.querySelector('.tm-internal-tools');
          const logos = modal.querySelectorAll('.tm-logo');
          const profListEl = modal.querySelector('.tm-prof-projects-list');
          const persListEl = modal.querySelector('.tm-pers-projects-list');

          if (titleEl) titleEl.textContent = tech.name;
          
          if (internalEl) {
            internalEl.innerHTML = tech.internalTools.map(tool => 
              `<span class="px-3 py-1 border border-cyan-500/20 text-[10px] text-cyan-500/80 font-bold bg-cyan-500/5">${tool}</span>`
            ).join('');
          }
          
          logos.forEach(logo => {
            logo.src = tech.logoUrl;
            logo.alt = `${tech.name} Logo`;
          });

          if (profListEl) {
            profListEl.innerHTML = renderProjectList(tech.professionalProjects, false);
          }

          if (persListEl) {
            persListEl.innerHTML = renderProjectList(tech.personalProjects, true);
          }
          
          modal.showModal();
        }
      });
    });

    closeBtn.addEventListener('click', (e) => {
      e.preventDefault();
      modal.close();
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.close();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupTechModal);
  } else {
    setupTechModal();
  }
</script>

<style>
  @reference "../styles/global.css";

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  dialog {
    margin: 0;
    padding: 0;
    max-width: none;
    max-height: none;
  }

  .bg-grid {
    background-image: radial-gradient(circle, rgba(6, 182, 212, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(6, 182, 212, 0.2);
    border-radius: 2px;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(6, 182, 212, 0.4);
  }

  /* --- Enhanced Glitch Animations --- */
  
  /* Constant very subtle jitter on main logo */
  .tm-main {
    animation: main-jitter 3s infinite;
  }

  @keyframes main-jitter {
    0%, 95%, 100% { transform: translate(0,0) scale(1); filter: drop-shadow(0 0 15px rgba(6,182,212,0.4)); }
    96% { transform: translate(1px, 1px) scale(1.01); filter: drop-shadow(-2px 0 red); }
    98% { transform: translate(-1px, -1px) scale(0.99); filter: drop-shadow(2px 0 blue); }
  }

  /* Glitch layers visible on hover */
  .group:hover .tm-glitch-1 {
    animation: glitch-anim-1 0.25s infinite linear;
    opacity: 0.8;
    filter: hue-rotate(90deg) saturate(3) drop-shadow(2px 0 #ff00ff);
  }

  .group:hover .tm-glitch-2 {
    animation: glitch-anim-2 0.25s infinite linear;
    opacity: 0.8;
    filter: hue-rotate(-90deg) saturate(3) drop-shadow(-2px 0 #00ffff);
  }

  .group:hover .tm-scanline {
    opacity: 1;
  }

  @keyframes glitch-anim-1 {
    0% { clip-path: inset(80% 0 0 0); transform: translate(-10px, -5px); }
    10% { clip-path: inset(10% 0 80% 0); transform: translate(10px, 5px); }
    20% { clip-path: inset(40% 0 40% 0); transform: translate(-10px, 5px); }
    30% { clip-path: inset(50% 0 30% 0); transform: translate(0px, -10px); }
    40% { clip-path: inset(20% 0 70% 0); transform: translate(10px, -5px); }
    50% { clip-path: inset(70% 0 10% 0); transform: translate(-5px, 10px); }
    60% { clip-path: inset(30% 0 50% 0); transform: translate(5px, -5px); }
    70% { clip-path: inset(10% 0 10% 0); transform: translate(-10px, 5px); }
    80% { clip-path: inset(50% 0 50% 0); transform: translate(0px, 0px); }
    90% { clip-path: inset(20% 0 20% 0); transform: translate(10px, 10px); }
    100% { clip-path: inset(80% 0 0 0); transform: translate(-10px, -5px); }
  }

  @keyframes glitch-anim-2 {
    0% { clip-path: inset(0 0 80% 0); transform: translate(10px, 5px); }
    10% { clip-path: inset(80% 0 10% 0); transform: translate(-10px, -5px); }
    20% { clip-path: inset(40% 0 40% 0); transform: translate(10px, -5px); }
    30% { clip-path: inset(30% 0 50% 0); transform: translate(0px, 10px); }
    40% { clip-path: inset(70% 0 20% 0); transform: translate(-10px, 5px); }
    50% { clip-path: inset(10% 0 70% 0); transform: translate(5px, -10px); }
    60% { clip-path: inset(50% 0 30% 0); transform: translate(-5px, 5px); }
    70% { clip-path: inset(10% 0 10% 0); transform: translate(10px, -5px); }
    80% { clip-path: inset(50% 0 50% 0); transform: translate(0px, 0px); }
    90% { clip-path: inset(20% 0 20% 0); transform: translate(-10px, -10px); }
    100% { clip-path: inset(0 0 80% 0); transform: translate(10px, 5px); }
  }

  @keyframes scanline {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }

  .animate-scanline {
    animation: scanline 2s linear infinite;
  }
</style>

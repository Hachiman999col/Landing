---
---

<div class=" z-50 flex gap-1 bg-black/40 p-1 rounded-sm border border-zinc-800/50" role="group" aria-label="Language selector">
  <button 
    id="btn-en" 
    class="w-7 h-7 flex items-center justify-center bg-transparent hover:bg-cyan-400/10 transition-all duration-200 rounded-xs grayscale hover:grayscale-0"
    title="English"
    aria-pressed="false"
    aria-label="Switch to English"
  >
    <img src="https://flagcdn.com/us.svg" alt="USA Flag" class="w-4 h-auto opacity-50 hover:opacity-100 transition-opacity" />
  </button>
  <div class="w-[1px] h-3 bg-zinc-800 self-center"></div>
  <button 
    id="btn-es" 
    class="w-7 h-7 flex items-center justify-center bg-transparent hover:bg-pink-500/10 transition-all duration-200 rounded-xs grayscale hover:grayscale-0"
    title="Español"
    aria-pressed="false"
    aria-label="Cambiar a Español"
  >
    <img src="https://flagcdn.com/co.svg" alt="Colombia Flag" class="w-4 h-auto opacity-50 hover:opacity-100 transition-opacity" />
  </button>
</div>

<script>
  const btnEn = document.getElementById('btn-en');
  const btnEs = document.getElementById('btn-es');
  const html = document.documentElement;

  const setLanguage = (lang: string) => {
    html.setAttribute('lang', lang);
    localStorage.setItem('preferred-lang', lang);
    
    if (lang === 'en') {
      btnEn?.classList.remove('grayscale');
      btnEn?.classList.add('border-cyan-500');
      btnEn?.setAttribute('aria-pressed', 'true');
      btnEs?.classList.add('grayscale');
      btnEs?.classList.remove('border-magenta-500');
      btnEs?.setAttribute('aria-pressed', 'false');
    } else {
      btnEs?.classList.remove('grayscale');
      btnEs?.classList.add('border-magenta-500');
      btnEs?.setAttribute('aria-pressed', 'true');
      btnEn?.classList.add('grayscale');
      btnEn?.classList.remove('border-cyan-500');
      btnEn?.setAttribute('aria-pressed', 'false');
    }
  };

  // Init from localStorage or browser default
  const savedLang = localStorage.getItem('preferred-lang') || (navigator.language.startsWith('es') ? 'es' : 'en');
  setLanguage(savedLang);

  btnEn?.addEventListener('click', () => setLanguage('en'));
  btnEs?.addEventListener('click', () => setLanguage('es'));
</script>

---
const techs = [
  {
    name: "ANGULAR",
    descEn: "Enterprise-grade framework for scalable web applications.",
    descEs: "Framework de nivel empresarial para aplicaciones web escalables.",
    color: "magenta",
    glow: "text-glow-magenta",
    border: "border-glow-magenta"
  },
  {
    name: "REACT",
    descEn: "Component-based library for interactive user interfaces.",
    descEs: "Biblioteca basada en componentes para interfaces de usuario interactivas.",
    color: "cyan",
    glow: "text-glow-cyan",
    border: "border-glow-cyan"
  },
  {
    name: "REACT NATIVE",
    descEn: "Cross-platform mobile development with native performance.",
    descEs: "Desarrollo móvil multiplataforma con rendimiento nativo.",
    color: "green",
    glow: "text-glow-green",
    border: "border-glow-green"
  }
];
---

<section class="px-6 md:px-12 py-20 bg-zinc-950/50">
  <div class="mb-12">
    <h2 class="text-2xl md:text-3xl font-bold tracking-widest text-white uppercase flex items-center gap-4">
      <span class="text-cyan-500">[</span> 
      <span class="lang-en">MODULES_LOADED</span>
      <span class="lang-es">MODULOS_CARGADOS</span>
      <span class="text-cyan-500">]</span>
      <div class="h-[2px] flex-1 bg-gradient-to-right from-cyan-500/50 to-transparent"></div>
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {techs.map((tech) => (
      <div class={`group relative p-8 border-2 border-zinc-800 bg-zinc-900/30 hover:bg-zinc-800/50 transition-all duration-300 ${tech.border}`}>
        <div class="absolute top-0 right-0 p-2 text-[10px] text-zinc-600 font-bold group-hover:text-zinc-400">
          v2.0.{Math.floor(Math.random() * 10)}
        </div>
        
        <h3 class={`text-xl font-bold mb-4 tracking-tighter ${tech.glow}`}>
          {tech.name}
        </h3>
        
        <div class="text-zinc-400 text-sm leading-relaxed mb-6 h-12">
          <p class="lang-en">{tech.descEn}</p>
          <p class="lang-es">{tech.descEs}</p>
        </div>
        
        <div class="flex items-center gap-2">
          <div class={`h-2 w-2 rounded-full animate-pulse ${tech.name === 'ANGULAR' ? 'bg-magenta-500 shadow-[0_0_5px_#ff00ff]' : tech.name === 'REACT' ? 'bg-cyan-500 shadow-[0_0_5px_#00f3ff]' : 'bg-green-500 shadow-[0_0_5px_#39ff14]'}`}></div>
          <span class="text-[10px] text-zinc-500 uppercase tracking-widest">
            <span class="lang-en">Running optimization...</span>
            <span class="lang-es">Ejecutando optimización...</span>
          </span>
        </div>
      </div>
    ))}
  </div>
</section>

---
import ProjectModal from './ProjectModal.astro';
import ProjectModalOnlyInfo from './ProjectModalOnlyInfo.astro';
import appNotesGif from '../assets/gifs/appNotas.gif';

const projects = [
  {
    id: "APP_NOTES",
    title: "appNotes",
    descEn:["A lightweight mobile application for note-taking. Built with React Native CLI using native Android modules for optimized performance." , "The project focuses on providing a smooth and efficient experience, leveraging the native capabilities of Android to ensure superior performance."],
    descEs: ["Una aplicación móvil ligera para toma de notas. Construida con React Native CLI utilizando módulos nativos de Android para un rendimiento optimizado." , 
    "El reto tecnológico fue integrar módulos nativos de Android para funciones críticas, logrando un rendimiento superior al de las aplicaciones híbridas tradicionales."],
    tech: ["REACT NATIVE", "TYPESCRIPT", "KOTLIN"],
    featuresEn: ["Native Performance", "Local Persistence", "Lightweight Build"],
    featuresEs: ["Rendimiento Nativo", "Persistencia Local", "Construcción Ligera"],
    links: [
      { label: "GITHUB", href: "https://github.com/Hachiman999col/appNotes" },
      { label: "APK.FILE", href: "https://github.com/Hachiman999col/appNotes/releases" }
    ],
    details: {      modal:"info" as const,
      languages: ["TYPESCRIPT", "KOTLIN"],
      internal: ["SQLITE", "JAVA NATIVE INTERFACE", "ANDROID SDK"],
      animationType: "nativeCLI",
      gifUrl: appNotesGif.src
    }
  },
    {
    id: "EXAMPLE_LIB",
    title: "LIBMOD",
    descEn:["This is a simple example of creating libraries with reusable component packaging and utilities to streamline projects in React." , 
    "The technological challenge was to create the lightest possible components that would avoid re-rendering components, thus optimizing application performance. To achieve this, a signal and event controller was implemented, avoiding external libraries."],
    descEs: ["Es un ejemplo sencillo de la creación de librerias con empaquetación de componentes reutilizables y utlidades para la agilización de proyectos en react" , 
    "El reto tecnológico fue la creación de componentes lo mas ligeros posibles que evitaran el re-renderizado de componentes, de esta forma se optimiza el rendimiento de la aplicación, para esto se implemento un contralador de señales y eventos evitando librerias externas."],
    tech: ["REACT", "TYPESCRIPT"],
    featuresEn: ["Lightweight", "Few dependencies", "Library"],
    featuresEs: ["Ligero", "Pocas dependencias", "Biblioteca"],
    links: [
      { label: "GITHUB", href: "https://github.com/Hachiman999col/libMod" },

    ],
    details: {
      modal:"onlyInfo" as const,
      languages: ["TYPESCRIPT", "REACT"],
      internal: ["TYPESCRIPT", "JSX", "VITE"],
      animationType: "nativeCLI",

      list:[
     "Custom Hooks", 
      "Custom Components" ,
      "Events controller" ,
       "Signal Controller"
    
    ]
      
    }
  }
];
---

<section id="projects" class="px-8 md:px-16 py-24">
  <div class="mb-16">
    <h2 class="text-xl md:text-2xl font-bold tracking-[0.3em] text-white uppercase flex items-center gap-6">
      <span class="text-pink-500">02 //</span> 
      <span class="lang-en">Featured_Work</span>
      <span class="lang-es">Proyectos_Destacados</span>
      <div class="h-[1px] flex-1 bg-zinc-900"></div>
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-12">
    {projects.map((project) => (
      <div class="group relative grid grid-cols-1 lg:grid-cols-12 gap-8 p-1 omarchy-window hover:border-pink-500/30 transition-all duration-500">
        <!-- Project Sidebar (Technical Specs) -->
        <div class="lg:col-span-4 border-b lg:border-b-0 lg:border-r border-zinc-800/50 p-6 bg-black/20">
          <div class="space-y-6">
            <div>
              <div class="text-[9px] text-zinc-600 font-bold uppercase tracking-[0.2em] mb-3">Project_ID</div>
              <div class="text-sm font-bold text-pink-500 tracking-tighter">{project.id}</div>
            </div>
            
            <div>
              <div class="text-[9px] text-zinc-600 font-bold uppercase tracking-[0.2em] mb-3">Stack_Trace</div>
              <div class="flex flex-wrap gap-2">
                {project.tech.map(t => (
                  <span class="px-2 py-0.5 border border-zinc-800 text-[9px] text-zinc-400 font-bold">{t}</span>
                ))}
              </div>
            </div>

            <div class="pt-4 border-t border-zinc-900/50">
              <div class="text-[9px] text-zinc-600 font-bold uppercase tracking-[0.2em] mb-3">Execution_Logs</div>
              <ul class="space-y-1">
                {project.featuresEn.map((f, i) => (
                  <li class="text-[10px] text-zinc-500 flex items-center gap-2">
                    <span class="text-pink-500/50">›</span>
                    <span class="lang-en">{f}</span>
                    <span class="lang-es">{project.featuresEs[i]}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Project Main Content -->
        <div class="lg:col-span-8 p-6 flex flex-col justify-between">
          <div>
            <div class="flex justify-between items-start mb-6">
              <h3 class="text-2xl md:text-3xl font-bold text-white tracking-tighter group-hover:text-glow-magenta transition-all">
                {project.title}
              </h3>
              <div class="text-[9px] text-zinc-700 font-mono">v1.0.4 // STABLE</div>
            </div>
            
            <div class="text-zinc-400 text-sm leading-relaxed max-w-2xl mb-8">
        
              {project.descEn.map((desc) => (
                <p class="lang-en mt-2">{desc}</p>
              ))}
    
              {project.descEs.map((desc) => (
                <p class="lang-es mt-2">{desc}</p>
              ))}
    
            </div>
          </div>

          <div class="flex flex-wrap gap-4 mt-auto">
            {project.links.map(link => (
              <a 
                href={link.href}
                target="_blank"
                class="px-4 py-2 border border-zinc-800 hover:border-pink-500/50 hover:bg-pink-500/5 text-zinc-500 hover:text-pink-500 text-[10px] font-bold tracking-widest transition-all duration-300 rounded-sm no-underline"
              >
                {link.label}
              </a>
            ))}
            {project.details.modal === "onlyInfo" ? (
              <button 
                data-project-id={project.id}
                class="open-info-modal-btn px-4 py-2 border border-cyan-500/30 bg-cyan-500/5 hover:bg-cyan-500/10 text-cyan-500/70 hover:text-cyan-500 text-[10px] font-bold tracking-widest transition-all duration-300 rounded-sm flex items-center gap-2"
              >
                <span class="w-1.5 h-1.5 bg-cyan-500 animate-pulse rounded-full"></span>
                CORE_FLOW.SH
              </button>
            ) : (
              <button 
                data-project-id={project.id}
                class="open-modal-btn px-4 py-2 border border-pink-500/30 bg-pink-500/5 hover:bg-pink-500/10 text-pink-500/70 hover:text-pink-500 text-[10px] font-bold tracking-widest transition-all duration-300 rounded-sm flex items-center gap-2"
              >
                <span class="w-1.5 h-1.5 bg-pink-500 animate-pulse rounded-full"></span>
                INFO_SYSTEM.EXE
              </button>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Background Scanline effect local to section -->
  <div class="mt-16 text-center">
    <div class="inline-block text-[9px] text-zinc-800 font-mono animate-pulse">
      -- END OF DIRECTORY --
    </div>
  </div>

  <ProjectModal projects={projects} />
  <ProjectModalOnlyInfo projects={projects} />
</section>
